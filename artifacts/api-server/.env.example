PORT=8080

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
VITE_FIREBASE_DATABASE_URL=https://<project>.firebaseio.com

# Microsoft Azure (for MS SSO and email via Microsoft Graph)
VITE_AZURE_CLIENT_ID=<azure-app-client-id>
VITE_AZURE_TENANT_ID=<azure-tenant-id>
AZURE_CLIENT_SECRET=<azure-client-secret>
MS_SENDER_EMAIL=noreply@ethinos.com

# CORS — comma-separated list of allowed browser origins.
# Required in all environments. Missing or wrong values will block browser requests.
# Example: https://pmt.ethinos.com,https://pmt.ethinos.com/mobile
# For local development: http://localhost:5173,http://localhost:5174
CORS_ORIGINS=https://pmt.ethinos.com

# Admin API key — used to authenticate export and digest-trigger endpoints.
# Pass as the x-admin-api-key request header (never in the URL query string).
PMT_EXPORT_API_KEY=<random-secret-string>

# Optional: redirect all notification emails to this address for testing
# NOTIFY_TEST_EMAIL=dev@ethinos.com
